FROM python:3.11-slim

WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Build-time args (can be overridden by --build-arg)
ARG SECRET_KEY=dev-secret-change-me
ARG MONGO_URI=mongodb://localhost:27017/brandvisor
ARG OPENAI_API_KEY=
ARG OPENAI_KEY=
ARG REDIS_URL=redis://localhost:6379/0
ARG CELERY_BROKER_URL=redis://localhost:6379/0
ARG CELERY_RESULT_BACKEND=redis://localhost:6379/1
ARG PUBLIC_BASE_URL=http://localhost:5000
ARG CORS_ORIGINS=http://localhost:3000
ARG LLM_MODEL=gpt-5.2-2025-12-11
ARG LLM_TEMPERATURE=0.2
ARG LLM_TIMEOUT=60
ARG CREATIVE_API_TOKEN=
ARG CREATIVE_API_URL=

# Runtime env vars consumed by app config/env validator
ENV SECRET_KEY=${SECRET_KEY}
ENV MONGO_URI=${MONGO_URI}
ENV OPENAI_API_KEY=${OPENAI_API_KEY}
ENV OPENAI_KEY=${OPENAI_KEY}
ENV REDIS_URL=${REDIS_URL}
ENV CELERY_BROKER_URL=${CELERY_BROKER_URL}
ENV CELERY_RESULT_BACKEND=${CELERY_RESULT_BACKEND}
ENV PUBLIC_BASE_URL=${PUBLIC_BASE_URL}
ENV CORS_ORIGINS=${CORS_ORIGINS}
ENV LLM_MODEL=${LLM_MODEL}
ENV LLM_TEMPERATURE=${LLM_TEMPERATURE}
ENV LLM_TIMEOUT=${LLM_TIMEOUT}
ENV CREATIVE_API_TOKEN=${CREATIVE_API_TOKEN}
ENV CREATIVE_API_URL=${CREATIVE_API_URL}

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 5000
CMD ["gunicorn", "-b", "0.0.0.0:5000", "--worker-class", "gthread", "--threads", "8", "--timeout", "0", "wsgi:app"]
